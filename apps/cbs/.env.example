# ─── OpenClaw Webhook ───────────────────────────────────────────
# Find this in Patrick's OpenClaw Gateway settings (openclaw.ai/settings/gateway)
OPENCLAW_WEBHOOK_URL=http://YOUR_OPENCLAW_HOST:PORT/hooks/agent
OPENCLAW_TOKEN=your_secret_token_here

# ─── Output ─────────────────────────────────────────────────────
# Where to save the PDF locally before sending
OUTPUT_DIR=C:/Users/Julien/Desktop/CBS-Leads-Output

# ─── File Sharing (optional) ────────────────────────────────────
# If you share a Dropbox/Google Drive folder with Patrick,
# put the public base URL here so his agent gets a download link
# Leave blank if you're just sending the local file path
FILE_BASE_URL=

# ─── OpenClaw Delivery Channel ──────────────────────────────────
# Which channel Patrick's agent delivers the notification to
# Options: whatsapp, telegram, discord, slack, signal, last
DELIVERY_CHANNEL=whatsapp
